{
  "manifest_version": 3,
  "name": "Screen Portal",
  "version": "1.0.0",
  "description": "Capture a region of your screen and share it as a Chrome tab in Google Meet.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Screen Portal"
  },
  "background": {
    "service_worker": "background.js"
  }
}
